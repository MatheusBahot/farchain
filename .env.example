# =============================================================
# FARCHAIN - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================

# ---- Banco de Dados ----
DATABASE_URL="postgresql://farchain:farchain_secret@localhost:5432/farchain_db?schema=public"
POSTGRES_USER=farchain
POSTGRES_PASSWORD=farchain_secret
POSTGRES_DB=farchain_db
POSTGRES_PORT=5432

# ---- Backend ----
NODE_ENV=development
BACKEND_PORT=3001
API_PREFIX=api/v1

# ---- JWT ----
JWT_SECRET=seu_jwt_secret_super_seguro_minimo_256_bits
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=seu_refresh_secret_super_seguro_minimo_256_bits
JWT_REFRESH_EXPIRES_IN=7d

# ---- Frontend ----
VITE_API_URL=http://localhost:3001/api/v1
VITE_APP_NAME=FarChain
VITE_APP_VERSION=1.0.0

# ---- Blockchain ----
BLOCKCHAIN_DIFFICULTY=2
BLOCKCHAIN_GENESIS_DATA=FarChain_Genesis_Block_SUS_CEAF

# ---- Redis (Cache) ----
REDIS_URL=redis://localhost:6379

# ---- QR Code ----
QR_BASE_URL=http://localhost:5173/rastreio

# ---- Rate Limiting ----
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Logs ----
LOG_LEVEL=debug
