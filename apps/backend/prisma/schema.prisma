// FarChain - Schema Prisma
// Plataforma de Rastreabilidade Farmacêutica CEAF/SUS

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  GESTOR_ESTADUAL
  GESTOR_MUNICIPAL
  FARMACEUTICO
  OPERADOR_CAF
  AUDITOR
  VISUALIZADOR
  PACIENTE
}

enum StatusLote {
  ATIVO
  QUARENTENA
  BLOQUEADO
  VENCIDO
  RECOLHIDO
  DESCARTADO
  DEVOLVIDO
}

enum TipoMovimentacao {
  ENTRADA_ESTOQUE
  SAIDA_DISTRIBUICAO
  TRANSFERENCIA_INTERNA
  DISPENSACAO_PACIENTE
  DEVOLUCAO_PACIENTE
  DEVOLUCAO_FORNECEDOR
  PERDA
  VENCIMENTO
  DESCARTE
  BLOQUEIO_SANITARIO
  RECOLHIMENTO
  AJUSTE_INVENTARIO
}

enum ClasseCEAF {
  COMPONENTE_I_A
  COMPONENTE_I_B
  COMPONENTE_II
  COMPONENTE_III
}

enum FormaFarmaceutica {
  COMPRIMIDO
  CAPSULA
  SOLUCAO_ORAL
  SOLUCAO_INJETAVEL
  SUSPENSAO_ORAL
  POMADA
  CREME
  GEL
  INALACAO
  SUPOSITORIO
  ADESIVO_TRANSDERMICO
  PO_INJETAVEL
  FRASCO_AMPOLA
  SERINGA_PREENCHIDA
  CANETA_APLICADORA
}

enum StatusFarmacovigilancia {
  ABERTO
  EM_INVESTIGACAO
  ENCERRADO
  NOTIFICADO_ANVISA
}

enum TipoEventoBlockchain {
  CADASTRO_MEDICAMENTO
  CRIACAO_LOTE
  ENTRADA_ESTOQUE
  MOVIMENTACAO
  DISPENSACAO
  FARMACOVIGILANCIA
  AUDITORIA
  RECOLHIMENTO
  BLOQUEIO
  TEMPERATURA_ALERTA
}

enum StatusAlerta {
  ATIVO
  RECONHECIDO
  RESOLVIDO
  IGNORADO
}

// ============================================================
// USUÁRIO E AUTENTICAÇÃO
// ============================================================

model Usuario {
  id               String    @id @default(uuid())
  nome             String
  email            String    @unique
  cpf              String    @unique
  senhaHash        String
  role             Role      @default(VISUALIZADOR)
  ativo            Boolean   @default(true)
  emailVerificado  Boolean   @default(false)
  mfaAtivo         Boolean   @default(false)
  mfaSecret        String?
  avatarUrl        String?
  telefone         String?
  crfNumero        String? // Registro CRF para farmacêuticos
  unidadeId        String?
  ultimoLogin      DateTime?
  refreshTokenHash String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  unidade            UnidadeSaude?       @relation(fields: [unidadeId], references: [id])
  movimentacoes      Movimentacao[]
  dispensacoes       Dispensacao[]
  auditLogs          AuditLog[]
  eventosBlockchain  EventoBlockchain[]
  farmacovigilancias FarmacoVigilancia[]
  alertas            Alerta[]

  @@map("usuarios")
}

// ============================================================
// ORGANIZAÇÃO GEOGRÁFICA
// ============================================================

model DistritoSanitario {
  id          String   @id @default(uuid())
  codigo      String   @unique
  nome        String
  municipio   String   @default("Salvador")
  uf          String   @default("BA")
  populacao   Int?
  area        Float?
  responsavel String?
  telefone    String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unidades UnidadeSaude[]

  @@map("distritos_sanitarios")
}

model UnidadeSaude {
  id          String   @id @default(uuid())
  cnes        String?  @unique
  nome        String
  tipo        String // CAF, UBS, Hospital, Policlínica, etc.
  cnpj        String?
  telefone    String?
  email       String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  municipio   String?
  uf          String?
  cep         String?
  latitude    Float?
  longitude   Float?
  ehCAF       Boolean  @default(false)
  distritoId  String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  distrito             DistritoSanitario? @relation(fields: [distritoId], references: [id])
  usuarios             Usuario[]
  estoque              EstoqueLote[]
  movimentacoesOrigem  Movimentacao[]     @relation("MovOrigem")
  movimentacoesDestino Movimentacao[]     @relation("MovDestino")
  dispensacoes         Dispensacao[]

  @@map("unidades_saude")
}

// ============================================================
// MEDICAMENTOS
// ============================================================

model Medicamento {
  id                     String            @id @default(uuid())
  dcb                    String // Denominação Comum Brasileira
  nomeComercial          String?
  principioAtivo         String
  fabricante             String
  distribuidor           String?
  registroSanitario      String?           @unique // Registro ANVISA
  classeTerapeutica      String
  subclasse              String?
  formaFarmaceutica      FormaFarmaceutica
  concentracao           String
  apresentacao           String // ex: "30 comprimidos"
  viaAdministracao       String?
  classeCEAF             ClasseCEAF
  protocoloClinico       String?
  cid10                  String? // CIDs indicados
  gtin                   String? // Global Trade Item Number
  codigoEAN              String?
  temperaturaMin         Float? // °C
  temperaturaMax         Float? // °C
  requireCadeiaFria      Boolean           @default(false)
  condicoesArmazenamento String?
  custoCentral           Float? // R$ custo médio RENAME
  ativo                  Boolean           @default(true)
  observacoes            String?
  bula                   String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  lotes        Lote[]
  dispensacoes Dispensacao[]

  @@map("medicamentos")
}

// ============================================================
// LOTES
// ============================================================

model Lote {
  id                  String     @id @default(uuid())
  identificadorUnico  String     @unique @default(uuid()) // UUID global do lote
  numeroLote          String
  medicamentoId       String
  fabricante          String
  dataFabricacao      DateTime
  dataValidade        DateTime
  quantidadeProduzida Int
  quantidadeRecebida  Int
  qrCodeUrl           String?
  qrCodeHash          String?
  statusSanitario     StatusLote @default(ATIVO)
  hashCriptografico   String     @unique
  notaFiscal          String?
  fornecedor          String?
  observacoes         String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  medicamento        Medicamento           @relation(fields: [medicamentoId], references: [id])
  estoque            EstoqueLote[]
  movimentacoes      Movimentacao[]
  dispensacoes       Dispensacao[]
  temperaturas       RegistroTemperatura[]
  farmacovigilancias FarmacoVigilancia[]
  eventosBlockchain  EventoBlockchain[]

  @@map("lotes")
}

model EstoqueLote {
  id          String   @id @default(uuid())
  loteId      String
  unidadeId   String
  quantidade  Int
  localizacao String? // ex: "Prateleira A3, Câmara 2"
  updatedAt   DateTime @updatedAt

  lote    Lote         @relation(fields: [loteId], references: [id])
  unidade UnidadeSaude @relation(fields: [unidadeId], references: [id])

  @@unique([loteId, unidadeId])
  @@map("estoque_lotes")
}

// ============================================================
// MOVIMENTAÇÕES
// ============================================================

model Movimentacao {
  id             String           @id @default(uuid())
  loteId         String
  tipo           TipoMovimentacao
  quantidade     Int
  origemId       String?
  destinoId      String?
  usuarioId      String
  justificativa  String?
  documentoRef   String? // NF, Ofício, etc.
  hashBlockchain String?
  ip             String?
  geolocalizacao String?
  createdAt      DateTime         @default(now())

  lote    Lote          @relation(fields: [loteId], references: [id])
  origem  UnidadeSaude? @relation("MovOrigem", fields: [origemId], references: [id])
  destino UnidadeSaude? @relation("MovDestino", fields: [destinoId], references: [id])
  usuario Usuario       @relation(fields: [usuarioId], references: [id])

  @@map("movimentacoes")
}

// ============================================================
// DISPENSAÇÃO AO PACIENTE
// ============================================================

model Paciente {
  id             String    @id @default(uuid())
  cpfHash        String    @unique // CPF anonimizado via SHA-256
  cartaoSusHash  String?   @unique
  nomeHash       String? // Nome pseudonimizado
  dataNascimento DateTime?
  genero         String?
  municipio      String?
  uf             String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  dispensacoes Dispensacao[]

  @@map("pacientes")
}

model Dispensacao {
  id                String   @id @default(uuid())
  loteId            String
  medicamentoId     String
  pacienteId        String
  unidadeId         String
  usuarioId         String
  quantidade        Int
  dataDispensacao   DateTime @default(now())
  dosagem           String?
  duracaoTratamento String?
  cid10             String?
  prescricaoRef     String?
  hashBlockchain    String?
  observacoes       String?

  lote        Lote         @relation(fields: [loteId], references: [id])
  medicamento Medicamento  @relation(fields: [medicamentoId], references: [id])
  paciente    Paciente     @relation(fields: [pacienteId], references: [id])
  unidade     UnidadeSaude @relation(fields: [unidadeId], references: [id])
  usuario     Usuario      @relation(fields: [usuarioId], references: [id])

  @@map("dispensacoes")
}

// ============================================================
// FARMACOVIGILÂNCIA
// ============================================================

model FarmacoVigilancia {
  id             String                  @id @default(uuid())
  loteId         String
  usuarioId      String
  tipoEvento     String // RAM, Queixa Técnica, Desvio de Qualidade, Falha Terapêutica
  descricao      String
  gravidade      String // Leve, Moderado, Grave, Fatal
  status         StatusFarmacovigilancia @default(ABERTO)
  dataCadastro   DateTime                @default(now())
  dataOcorrencia DateTime
  acaoTomada     String?
  notificacaoRef String? // Número notificação ANVISA
  hashBlockchain String?
  resolucao      String?
  updatedAt      DateTime                @updatedAt

  lote    Lote    @relation(fields: [loteId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("farmacovigilancia")
}

// ============================================================
// BLOCKCHAIN LEDGER
// ============================================================

model BlocoBlockchain {
  id           String   @id @default(uuid())
  indice       Int      @unique
  timestamp    DateTime @default(now())
  hashAnterior String
  hashAtual    String   @unique
  nonce        Int
  dificuldade  Int      @default(2)
  dadosJson    String // JSON do bloco completo
  validado     Boolean  @default(true)
  createdAt    DateTime @default(now())

  eventos EventoBlockchain[]

  @@map("blocos_blockchain")
}

model EventoBlockchain {
  id           String               @id @default(uuid())
  blocoId      String?
  tipoEvento   TipoEventoBlockchain
  entidadeId   String // ID da entidade relacionada
  entidadeTipo String // "Lote", "Movimentacao", etc.
  usuarioId    String?
  dados        String // JSON dos dados do evento
  hashDados    String
  assinatura   String?
  timestamp    DateTime             @default(now())

  bloco   BlocoBlockchain? @relation(fields: [blocoId], references: [id])
  usuario Usuario?         @relation(fields: [usuarioId], references: [id])
  lote    Lote?            @relation(fields: [entidadeId], references: [id], map: "fk_evento_lote")

  @@map("eventos_blockchain")
}

// ============================================================
// CADEIA FRIA / TEMPERATURA
// ============================================================

model RegistroTemperatura {
  id           String   @id @default(uuid())
  loteId       String
  temperatura  Float
  umidade      Float?
  sensor       String?
  localizacao  String?
  conformidade Boolean  @default(true)
  alertaGerado Boolean  @default(false)
  timestamp    DateTime @default(now())

  lote Lote @relation(fields: [loteId], references: [id])

  @@map("registros_temperatura")
}

model Alerta {
  id           String       @id @default(uuid())
  tipo         String
  mensagem     String
  entidadeId   String
  entidadeTipo String
  usuarioId    String?
  status       StatusAlerta @default(ATIVO)
  prioridade   String       @default("MEDIA")
  createdAt    DateTime     @default(now())
  resolvidoEm  DateTime?

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("alertas")
}

// ============================================================
// AUDITORIA
// ============================================================

model AuditLog {
  id             String   @id @default(uuid())
  usuarioId      String?
  acao           String
  entidade       String
  entidadeId     String?
  valorAntes     String? // JSON do valor anterior
  valorDepois    String? // JSON do novo valor
  ip             String?
  userAgent      String?
  geolocalizacao String?
  timestamp      DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("audit_logs")
}
